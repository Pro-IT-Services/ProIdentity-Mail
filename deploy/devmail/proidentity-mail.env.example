PROIDENTITY_HTTP_ADDR=127.0.0.1:8080
PROIDENTITY_GROUPWARE_ADDR=127.0.0.1:8081
PROIDENTITY_WEBMAIL_ADDR=127.0.0.1:8082
PROIDENTITY_DB_NAME=proidentity_mail
PROIDENTITY_DB_USER=proidentity_mail
PROIDENTITY_DB_PASSWORD=change-me
PROIDENTITY_DB_DSN=proidentity_mail:change-me@tcp(127.0.0.1:3306)/proidentity_mail?parseTime=true&multiStatements=true
PROIDENTITY_BACKUP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
PROIDENTITY_AUTH_POLICY_TOKEN=change-me-auth-policy-token
PROIDENTITY_AUTH_POLICY_NONCE=change-me-auth-policy-nonce
PROIDENTITY_CONFIG_DIR=/etc/proidentity-mail/generated
PROIDENTITY_MAILCTL_PATH=/opt/proidentity-mail/bin/mailctl
PROIDENTITY_CONFIG_APPLY_REQUEST_PATH=/etc/proidentity-mail/apply-request
PROIDENTITY_MAIL_HOSTNAME=mail.local
PROIDENTITY_PUBLIC_IPV4=
PROIDENTITY_PUBLIC_IPV6=
PROIDENTITY_MAIL_TLS_CERT_PATH=
PROIDENTITY_MAIL_TLS_KEY_PATH=
PROIDENTITY_CLOUDFLARE_CERT_DOMAIN=
