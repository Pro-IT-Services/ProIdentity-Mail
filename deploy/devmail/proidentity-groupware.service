[Unit]
Description=ProIdentity Mail Groupware DAV
After=network-online.target mariadb.service
Wants=network-online.target

[Service]
Type=simple
User=proidentity
Group=proidentity
EnvironmentFile=/etc/proidentity-mail/proidentity-mail.env
ExecStart=/opt/proidentity-mail/bin/groupware
Restart=on-failure
RestartSec=5s
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
